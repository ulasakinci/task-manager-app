/**
 * Home Page - Ana sayfa (CRUD işlemleri)
 * 
 * Tasarım: Modern Minimalist Produktivite
 * Mizanpaj: Asimetrik Tasarım (Sol: Görevler, Sağ: İstatistikler)
 */

import { useState } from 'react';
import { Task, TaskStatus, TaskPriority } from '@/interfaces/Task';
import { useTask } from '@/contexts/TaskContext';
import { Button } from '@/components/ui/button';
import { Dialog, DialogContent, DialogHeader, DialogTitle } from '@/components/ui/dialog';
import { TaskCard } from '@/components/TaskCard';
import { TaskForm } from '@/components/TaskForm';
import { TaskFilter } from '@/components/TaskFilter';
import { TaskStats } from '@/components/TaskStats';
import { Plus, Trash2 } from 'lucide-react';
import { toast } from 'sonner';

export default function Home() {
  const { tasks, addTask, updateTask, deleteTask, clearCompleted } = useTask();

  // State
  const [isAddOpen, setIsAddOpen] = useState(false);
  const [searchQuery, setSearchQuery] = useState('');
  const [statusFilter, setStatusFilter] = useState<TaskStatus | 'all'>('all');
  const [priorityFilter, setPriorityFilter] = useState<TaskPriority | 'all'>('all');

  // Filtreleme
  const filteredTasks = tasks.filter((task) => {
    const matchesSearch =
      task.title.toLowerCase().includes(searchQuery.toLowerCase()) ||
      (task.description?.toLowerCase().includes(searchQuery.toLowerCase()) ?? false);

    const matchesStatus = statusFilter === 'all' || task.status === statusFilter;
    const matchesPriority = priorityFilter === 'all' || task.priority === priorityFilter;

    return matchesSearch && matchesStatus && matchesPriority;
  });

  // İşlemler
  const handleAddTask = (task: Omit<Task, 'id' | 'createdAt' | 'updatedAt'>) => {
    addTask(task);
    setIsAddOpen(false);
    toast.success('Görev başarıyla eklendi!');
  };

  const handleUpdateTask = (id: string, updates: any) => {
    updateTask(id, updates);
    toast.success('Görev başarıyla güncellendi!');
  };

  const handleDeleteTask = (id: string) => {
    deleteTask(id);
    toast.success('Görev başarıyla silindi!');
  };

  const handleClearCompleted = () => {
    const completedCount = tasks.filter((t) => t.status === 'completed').length;
    if (completedCount === 0) {
      toast.info('Tamamlanmış görev yok.');
      return;
    }
    clearCompleted();
    toast.success(`${completedCount} tamamlanmış görev silindi!`);
  };

  return (
    <div className="min-h-screen bg-gradient-to-br from-gray-50 to-gray-100">
      {/* Header */}
      <header className="bg-white border-b border-gray-200 sticky top-0 z-20">
        <div className="container mx-auto px-4 py-4">
          <div className="flex items-center justify-between">
            <div>
              <h1 className="text-3xl font-bold text-gray-900">Görev Yöneticisi</h1>
              <p className="text-sm text-gray-600 mt-1">Görevlerinizi yönetin ve başarıyı takip edin</p>
            </div>
            <Button
              onClick={() => setIsAddOpen(true)}
              className="bg-blue-600 hover:bg-blue-700 gap-2"
            >
              <Plus className="w-4 h-4" />
              Yeni Görev
            </Button>
          </div>
        </div>
      </header>

      {/* Main Content */}
      <main className="container mx-auto px-4 py-8">
        <div className="grid grid-cols-1 lg:grid-cols-3 gap-6">
          {/* Sol Taraf - Görevler */}
          <div className="lg:col-span-2 space-y-4">
            {/* Filtreleme */}
            <TaskFilter
              searchQuery={searchQuery}
              onSearchChange={setSearchQuery}
              statusFilter={statusFilter}
              onStatusChange={setStatusFilter}
              priorityFilter={priorityFilter}
              onPriorityChange={setPriorityFilter}
            />

            {/* Görev Listesi */}
            <div className="space-y-3">
              {filteredTasks.length > 0 ? (
                filteredTasks.map((task) => (
                  <TaskCard
                    key={task.id}
                    task={task}
                    onUpdate={handleUpdateTask}
                    onDelete={handleDeleteTask}
                  />
                ))
              ) : (
                <div className="bg-white rounded-xl p-8 text-center shadow-sm border border-gray-100">
                  <p className="text-gray-500 mb-4">
                    {searchQuery || statusFilter !== 'all' || priorityFilter !== 'all'
                      ? 'Filtreleme kriterlerine uygun görev bulunamadı.'
                      : 'Henüz görev yok. Yeni bir görev ekleyerek başlayın!'}
                  </p>
                  {(searchQuery || statusFilter !== 'all' || priorityFilter !== 'all') && (
                    <Button
                      variant="outline"
                      onClick={() => {
                        setSearchQuery('');
                        setStatusFilter('all');
                        setPriorityFilter('all');
                      }}
                    >
                      Filtreleri Sıfırla
                    </Button>
                  )}
                </div>
              )}
            </div>

            {/* Tamamlanmış Görevleri Temizle */}
            {tasks.some((t) => t.status === 'completed') && (
              <div className="flex justify-end pt-4">
                <Button
                  variant="outline"
                  onClick={handleClearCompleted}
                  className="gap-2 text-red-600 hover:text-red-700 hover:bg-red-50"
                >
                  <Trash2 className="w-4 h-4" />
                  Tamamlanmış Görevleri Temizle
                </Button>
              </div>
            )}
          </div>

          {/* Sağ Taraf - İstatistikler */}
          <div className="lg:col-span-1">
            <TaskStats tasks={tasks} />
          </div>
        </div>
      </main>

      {/* Yeni Görev Dialog */}
      <Dialog open={isAddOpen} onOpenChange={setIsAddOpen}>
        <DialogContent className="sm:max-w-[425px]">
          <DialogHeader>
            <DialogTitle>Yeni Görev Ekle</DialogTitle>
          </DialogHeader>
          <TaskForm
            onSubmit={handleAddTask}
            onCancel={() => setIsAddOpen(false)}
          />
        </DialogContent>
      </Dialog>
    </div>
  );
}
